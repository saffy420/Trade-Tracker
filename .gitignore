[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/

# JetBrains Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# Avalonia
**/bin/
**/obj/

# Logs
logs/
*.log

