<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Tracker.Avalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="Tracker.Avalonia.Views.CoordinateEditorView"
        x:DataType="vm:CoordinateEditorViewModel"
        Title="Coordinate Editor"
        Width="800" Height="600"
        Background="#14141E"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Title Bar -->
        <Border Grid.Row="0" Background="#1E1E2E" Padding="15,10">
            <TextBlock Text="Coordinate Editor" 
                      FontSize="18" 
                      FontWeight="Bold"
                      Foreground="Cyan"/>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#23233E" Padding="10">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto">
                <!-- Search Box -->
                <TextBox Grid.Column="0" 
                        Text="{Binding SearchText}"
                        Watermark="Search coordinates..."
                        Margin="0,0,10,0">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.KeyBindings>
                </TextBox>
                
                <Button Grid.Column="1" 
                        Content="Search" 
                        Command="{Binding SearchCommand}"
                        Margin="0,0,5,0"/>
                
                <Button Grid.Column="2" 
                        Content="Add" 
                        Command="{Binding AddCoordinateCommand}"
                        Margin="0,0,5,0"/>
                
                <Button Grid.Column="3" 
                        Content="Reload" 
                        Command="{Binding ReloadCommand}"
                        Margin="0,0,5,0"/>
                
                <Button Grid.Column="4" 
                        Content="Save" 
                        Command="{Binding SaveCommand}"
                        Background="#2E7D32"
                        Margin="0,0,5,0"/>
                
                <Button Grid.Column="5" 
                        Content="Open Folder" 
                        Command="{Binding OpenConfigFolderCommand}"
                        Margin="0,0,5,0"
                        ToolTip.Tip="Open the folder containing coordinates.json"/>
                
                <Button Grid.Column="6" 
                        Content="Close" 
                        Click="CloseButton_Click"
                        Background="#C62828"/>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding Coordinates}"
                  SelectedItem="{Binding SelectedCoordinate}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  GridLinesVisibility="All"
                  BorderThickness="0"
                  Margin="10">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="Category" 
                                   Binding="{Binding Category, Mode=TwoWay}" 
                                   Width="120"
                                   IsReadOnly="False"/>
                
                <DataGridTextColumn Header="Key" 
                                   Binding="{Binding Key, Mode=TwoWay}" 
                                   Width="*"
                                   IsReadOnly="False"/>
                
                <DataGridTextColumn Header="Value" 
                                   Binding="{Binding Value, Mode=TwoWay}" 
                                   Width="120"
                                   IsReadOnly="False"/>
                
                <DataGridTemplateColumn Header="Actions" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Button Content="Test" 
                                       Command="{Binding $parent[Window].((vm:CoordinateEditorViewModel)DataContext).TestCoordinateCommand}"
                                       CommandParameter="{Binding}"
                                       Padding="8,4"
                                       FontSize="11"/>
                                <Button Content="Delete" 
                                       Command="{Binding $parent[Window].((vm:CoordinateEditorViewModel)DataContext).DeleteCoordinateCommand}"
                                       CommandParameter="{Binding}"
                                       Padding="8,4"
                                       FontSize="11"
                                       Background="#C62828"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="Black" Padding="10,8">
            <StackPanel Spacing="5">
                <TextBlock Text="{Binding StatusMessage}" 
                          Foreground="Lime" 
                          FontSize="11" 
                          FontFamily="Consolas"/>
                <TextBlock Foreground="#888888" 
                          FontSize="9" 
                          FontFamily="Consolas">
                    <Run Text="Config file: "/>
                    <Run Text="{Binding ConfigFilePath}" Foreground="#AAAAAA"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>

