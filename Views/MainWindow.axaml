<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Tracker.Avalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="540" d:DesignHeight="900"
        x:Class="Tracker.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Trade Monitor"
        Width="540" Height="900"
        Background="#14141E"
        TransparencyLevelHint="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        SystemDecorations="None"
        Topmost="True"
        CanResize="True">

    <Window.Styles>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="50,*,40">
        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#1E1E2E" PointerPressed="TitleBar_PointerPressed">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" 
                          Text="Trade Monitor" 
                          VerticalAlignment="Center" 
                          Margin="15,0,0,0"
                          FontSize="16" 
                          FontWeight="Bold"
                          Foreground="Cyan"/>
                
                <!-- Settings Button -->
                <Button Grid.Column="1" 
                        Classes="title-bar"
                        ToolTip.Tip="Settings (Coordinate Editor)"
                        Command="{Binding OpenCoordinateEditorCommand}"
                        CommandParameter="{Binding $parent[Window]}">
                    <PathIcon Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" 
                              Width="16" Height="16" Foreground="White"/>
                </Button>
                
                <!-- Minimize Button -->
                <Button Grid.Column="2" 
                        Classes="title-bar"
                        Click="MinimizeButton_Click"
                        ToolTip.Tip="Minimize">
                    <TextBlock Text="—" FontSize="18" FontWeight="Bold"/>
                </Button>
                
                <!-- Close Button -->
                <Button Grid.Column="3" 
                        Classes="title-bar"
                        Click="CloseButton_Click"
                        ToolTip.Tip="Close">
                    <TextBlock Text="×" FontSize="20" FontWeight="Bold"/>
                </Button>
            </Grid>
        </Border>

        <!-- Trade List -->
        <ScrollViewer Grid.Row="1" Padding="10">
            <ListBox ItemsSource="{Binding TradeGroups}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#23233E" 
                                CornerRadius="4" 
                                Padding="10"
                                Margin="0,0,0,5">
                            <StackPanel>
                                <!-- Game Header -->
                                <Border Background="#1E1E32" 
                                        CornerRadius="4" 
                                        Padding="10,8"
                                        Margin="0,0,0,8">
                                    <TextBlock Text="{Binding GameName}" 
                                              Foreground="Cyan" 
                                              FontSize="13" 
                                              FontWeight="Bold"/>
                                </Border>
                                
                                <!-- Markets -->
                                <ItemsControl ItemsSource="{Binding Trades}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#28284C" 
                                                    CornerRadius="3" 
                                                    Padding="10,6"
                                                    Margin="0,0,0,4">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Delete" 
                                                                 Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteTradeCommand}"
                                                                 CommandParameter="{Binding}"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <TextBlock Text="{Binding Market}" 
                                                          Foreground="LightGreen" 
                                                          FontSize="11"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="Black" Padding="10,8">
            <TextBlock Text="{Binding StatusMessage}" 
                      Foreground="Lime" 
                      FontSize="10" 
                      FontFamily="Consolas"
                      TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>

